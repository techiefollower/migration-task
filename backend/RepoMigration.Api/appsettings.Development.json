{
  "AzureAd": {
    "DisableAuthentication": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "GhCli": {
    "ExecutablePath": "C:\\Program Files\\GitHub CLI\\gh.exe"
  },
  "GhAdo2Gh": {
    "SkipInventoryReport": true
  },
  "Migration": {
    "MaxConcurrentJobs": 2,
    "TrustQueuedGitHubPat": true
  }
}
